cd /etc
vim zshrc
vim zprofile
vim zshrc_Apple_Terminal
man find
cd /
find ./ -type df -name "*zsh-syntax-*"
fzf
cd
zle -D unused-widget
vim .config/zsh/init.zsh
pwd
ls
l
history
time (conda activate base)
zi times
zi report
vim .zshenv
ts test
ts ls
tkss --all
tmux kill-session -a
tmux ls
tmux kill-pane -a
tmux kill-window -a
ta 1
tl
